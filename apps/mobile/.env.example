# Public client variables only
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.example.com

# Do not put private secrets in EXPO_PUBLIC variables.
# Do not commit real keys.
# Backend-only secrets belong in backend secret management, Expo/EAS secrets, or cloud secrets.

# Examples of values that must NOT be committed:
# DATABASE_URL=
# OPENAI_API_KEY=
# APPLE_PRIVATE_KEY=
# APP_STORE_CONNECT_API_KEY=
# STORAGE_SECRET=
# WEBHOOK_SECRET=
